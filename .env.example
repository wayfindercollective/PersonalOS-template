# ===== Required =====

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (message your bot /chatid after first run)
# REQUIRED for security — without this, any Telegram user can use the bot
ALLOWED_CHAT_ID=

# ===== Voice (optional) =====

# Local Whisper WebSocket STT (skip if you only use text)
# WHISPER_WS_URL=ws://127.0.0.1:9090

# ===== Video analysis (optional) =====

# Google AI Studio key for Gemini video analysis
# GOOGLE_API_KEY=

# ===== Ollama (optional local LLM) =====

# OLLAMA_URL_LOCAL=http://127.0.0.1:11434
# OLLAMA_DEFAULT_ENDPOINT=local
# OLLAMA_MODEL=llama3.2

# ===== LM Studio / LiteLLM (optional) =====

# Any OpenAI-compatible base URL on this PC or another machine on your network
# LMSTUDIO_URL=http://127.0.0.1:1234
# LMSTUDIO_API_KEY=
# LMSTUDIO_MODEL=

# ===== Google Calendar / Gmail (optional) =====

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Local CLI auth uses http://localhost:3456/callback by default
# GOOGLE_REDIRECT_URI=http://localhost:3456/callback
# GOOGLE_PERSONAL_EMAIL=you@example.com
# GOOGLE_WORK_EMAIL=work@example.com

# ===== Grok / xAI (optional) =====

# XAI_API_KEY=
# XAI_MODEL=latest
# XAI_API_BASE=https://api.x.ai/v1

# ===== Discord (optional) =====

# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USER_IDS=

# ===== Scheduler =====

SCHEDULER_ENABLED=true

# ===== WhatsApp bridge (optional) =====

# First run may show a QR code in the terminal
WA_ENABLED=false

# ===== Optional extras =====

# PRESENTATION_PORT=8787
# PRESENTATION_FUNNEL_HOST=localhost
# REMOTE_SSH_TARGET=user@other-machine
# MAC_SSH_TARGET=user@your-mac.local
# WORK_PROJECT_DIR=
# CONVEX_PROJECT_DIR=
# GITHUB_DEFAULT_REPO=owner/repo
